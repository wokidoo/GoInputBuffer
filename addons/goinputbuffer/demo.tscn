[gd_scene format=3 uid="uid://cvbgt67x4cjfp"]

[sub_resource type="GDScript" id="GDScript_n2q8g"]
resource_name = "demo"
script/source = "extends Control
@onready var consume_events_check_box: CheckBox = %ConsumeEventsCheckBox
@onready var input_sequence_text_edit: TextEdit = %InputSequenceTextEdit
@onready var result_text_label: RichTextLabel = %ResultTextLabel
@onready var buffer_frames_spin_box: SpinBox = %BufferFramesSpinBox

func _input(event: InputEvent) -> void:
	if event.is_pressed():
		GoInputBuffer.buffer_event(event,buffer_frames_spin_box.value)

func _process(delta: float) -> void:
	var sequence = input_sequence_text_edit.text.split(',',false)
	if GoInputBuffer.is_action_sequence_buffered(sequence,
		consume_events_check_box.button_pressed
		):
			result_text_label.text = \"[color=green]Sequence Found![/color]\"
			await get_tree().create_timer(2.0).timeout
			result_text_label.text = \"[color=red]Sequence Not Found...[/color]\"
			
"

