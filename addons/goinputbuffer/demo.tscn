[sub_resource type="GDScript" id="GDScript_mu2l4"]
resource_name = "input_buffer_display"
script/source = "extends VBoxContainer
@onready var buffer_spin_box: SpinBox = %BufferSpinBox

func _process(delta: float) -> void:
	get_children().map(func(node):
		node.queue_free()
		)
	for event in GoInputBuffer.get_input_buffer():
		var label:= Label.new()
		label.autowrap_mode =TextServer.AUTOWRAP_WORD_SMART
		label.text = str(event)
		add_child(label)
	buffer_spin_box.value = GoInputBuffer.get_input_buffer().size()
"

[sub_resource type="GDScript" id="GDScript_l37ct"]
resource_name = "text_edit"
script/source = "extends TextEdit

func _input(event: InputEvent) -> void:
	if event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_LEFT and event.is_pressed():
		if has_focus():
			var mouse_pos = get_local_mouse_position()
			var rect = Rect2(Vector2.ZERO,size)
			if not rect.has_point(mouse_pos):
				release_focus()
"

